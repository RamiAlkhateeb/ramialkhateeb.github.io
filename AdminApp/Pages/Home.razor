@page "/"
@using AdminApp.Services
@using System.Text.RegularExpressions
@inject LocalStorageService LocalStorage
@inject GitHubService GitHub
@inject NavigationManager NavManager

<div class="admin-container" style="max-width:950px; margin:40px auto; font-family:'Tajawal',sans-serif; direction:rtl; text-align:right; padding:0 20px;">
    
    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:3px solid #111; padding-bottom:20px; margin-bottom:30px;">
        <div>
            <h1 style="font-weight:800; font-size:2rem; margin:0; color:#111;">لوحة التحكم الإدارية</h1>
            <p style="color:#555; margin:5px 0 0 0; font-size:0.95rem;">مراقبة وإدارة محتوى موقع رامي الخطيب التعليمي</p>
        </div>
        <div style="display:flex; gap:10px;">
            <a href="/add-guide" style="background:#FF6B35; color:#fff; padding:10px 18px; border:2px solid #111; border-radius:4px; font-weight:700; text-decoration:none; box-shadow:3px 3px 0 #111;">
                <i class="fa-solid fa-plus"></i> دليل جديد
            </a>
            <a href="/add-post" style="background:#fff; color:#111; padding:10px 18px; border:2px solid #111; border-radius:4px; font-weight:700; text-decoration:none; box-shadow:3px 3px 0 #111;">
                <i class="fa-brands fa-linkedin"></i> مقال جديد
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="background:#FFEBE9; color:#CE1515; padding:15px; border:2px solid #CE1515; border-radius:6px; margin-bottom:25px; font-weight:700;">
            <i class="fa-solid fa-triangle-exclamation"></i> @errorMessage
        </div>
    }

    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:20px; margin-bottom:40px;">
        <div style="background:#fff; border:2.5px solid #111; padding:25px; border-radius:6px; box-shadow:4px 4px 0 #111;">
            <div style="font-size:0.9rem; color:#555; font-weight:700;">إجمالي الأدلة المنشورة</div>
            <div style="font-size:3rem; font-weight:800; color:#FF6B35; margin:10px 0;">@totalGuidesCount</div>
            <div style="font-size:0.8rem; color:#888;">ملفات منتجات مدفوعة / مجانية مفعّلة</div>
        </div>
        
        <div style="background:#fff; border:2.5px solid #111; padding:25px; border-radius:6px; box-shadow:4px 4px 0 #111;">
            <div style="font-size:0.9rem; color:#555; font-weight:700;">إجمالي منشورات ومقالات LinkedIn</div>
            <div style="font-size:3rem; font-weight:800; color:#111; margin:10px 0;">@totalPostsCount</div>
            <div style="font-size:0.8rem; color:#888;">روابط توجيه ومقالات سياقية نشطة</div>
        </div>
    </div>

    <div style="display:grid; grid-template-columns: 1fr; gap:30px;">
        <div style="background:#fff; border:2.5px solid #111; padding:25px; border-radius:6px; box-shadow:5px 5px 0 #111;">
            <h3 style="font-weight:800; font-size:1.25rem; border-bottom:2px dashed #111; padding-bottom:10px; margin-bottom:20px;">
                <i class="fa-solid fa-book" style="color:#FF6B35;"></i> الأدلة المكتشفة في الموقع الحالية (@totalGuidesCount)
            </h3>
            
            @if (isLoading)
            {
                <p style="color:#777; font-style:italic;">⏳ جاري قراءة ومسح مكونات index.html من مستودع GitHub...</p>
            }
            else if (totalGuidesCount == 0)
            {
                <p style="color:#888;">لا توجد أدلة معروضة ضمن نطاق الماركرز الحالي.</p>
            }
            else
            {
                <div style="display:flex; flex-direction:column; gap:12px;">
                    @foreach (var title in parsedGuides)
                    {
                        <div style="padding:12px; border:1.5px solid #111; background:#FAFAFA; border-radius:4px; display:flex; justify-content:space-between; align-items:center;">
                            <span style="font-weight:700; color:#111;">@title</span>
                            <span style="background:#FFEFEA; color:#FF6B35; font-size:0.75rem; padding:3px 8px; border-radius:4px; font-weight:700;">نشط عريض</span>
                        </div>
                    }
                </div>
            }
        </div>

        <div style="background:#fff; border:2.5px solid #111; padding:25px; border-radius:6px; box-shadow:5px 5px 0 #111;">                
            <h3 style="font-weight:800; font-size:1.25rem; border-bottom:2px dashed #111; padding-bottom:10px; margin-bottom:20px;">
                <i class="fa-brands fa-linkedin" style="color:#0077B5;"></i> منشورات ومقالات الـ LinkedIn الحالية (@totalPostsCount)
            </h3>
            
            @if (isLoading)
            {
                <p style="color:#777; font-style:italic;">⏳ جاري فحص بنية شجرة المستند الثابت...</p>
            }
            else if (totalPostsCount == 0)
            {
                <p style="color:#888;">لم يتم العثور على بطاقات مقالات حالية مضافة.</p>
            }
            else
            {
                <div style="display:flex; flex-direction:column; gap:12px;">
                    @foreach (var title in parsedPosts)
                    {
                        <div style="padding:12px; border:1.5px solid #111; background:#FAFAFA; border-radius:4px; display:flex; justify-content:space-between; align-items:center;">
                            <span style="font-weight:700; color:#111;">@title</span>
                            <span style="background:#E6F2F7; color:#0077B5; font-size:0.75rem; padding:3px 8px; border-radius:4px; font-weight:700;">منشور خارجي</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    
    private int totalGuidesCount = 0;
    private int totalPostsCount = 0;

    private List<string> parsedGuides = new();
    private List<string> parsedPosts = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Retrieve validation configurations out of runtime storage settings
            var token = await LocalStorage.GetItemAsync("github_token");
            var owner = await LocalStorage.GetItemAsync("github_owner");
            var repo  = await LocalStorage.GetItemAsync("github_repo");

            if (string.IsNullOrEmpty(token) || string.IsNullOrEmpty(owner) || string.IsNullOrEmpty(repo))
            {
                errorMessage = "تنبيه: إعدادات الاتصال بمستودع GitHub غير مكتملة. يرجى التوجه لصفحة الـ Settings لإعداد مفاتيح الوصول أولاً.";
                isLoading = false;
                return;
            }

            if (!GitHub.IsConfigured)
            {
                GitHub.Initialize(token, owner, repo);
            }

            // Pull live HTML layout document direct stream raw string 
            string indexHtmlContent = await GitHub.GetFileRawAsync("index.html");

            // Execute automated contextual scanners to collect item strings
            ParseGuidesData(indexHtmlContent);
            ParsePostsData(indexHtmlContent);
        }
        catch (Exception ex)
        {
            errorMessage = $"خطأ أثناء تحميل بيانات المستودع: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ParseGuidesData(string html)
    {
        parsedGuides.Clear();
        
        int startIdx = html.IndexOf("", StringComparison.OrdinalIgnoreCase);
        int endIdx = html.IndexOf("", StringComparison.OrdinalIgnoreCase);
        
        if (startIdx < 0 || endIdx < 0) return;
        
        string guidesSegment = html.Substring(startIdx, endIdx - startIdx);
        
        var regex = new Regex(@"class\s*=\s*['""][^'""]*guide-card-title[^'""]*['""][^>]*>\s*(.*?)\s*</", RegexOptions.IgnoreCase | RegexOptions.Singleline);
        var matches = regex.Matches(guidesSegment);

        foreach (Match match in matches)
        {
            if (match.Groups.Count > 1)
            {
                // Fixed: explicitly call string.Empty instead of compiler ambiguous String.Empty
                string title = Regex.Replace(match.Groups[1].Value, "<.*?>", string.Empty).Trim();
                parsedGuides.Add(title);
            }
        }
        
        totalGuidesCount = parsedGuides.Count;
    }

    private void ParsePostsData(string html)
    {
        parsedPosts.Clear();
        
        int startIdx = html.IndexOf("", StringComparison.OrdinalIgnoreCase);
        int endIdx = html.IndexOf("", StringComparison.OrdinalIgnoreCase);
        
        if (startIdx < 0 || endIdx < 0) return;
        
        string postsSegment = html.Substring(startIdx, endIdx - startIdx);
        
        var regex = new Regex(@"class\s*=\s*['""][^'""]*post-card-title[^'""]*['""][^>]*>\s*(.*?)\s*</", RegexOptions.IgnoreCase | RegexOptions.Singleline);
        var matches = regex.Matches(postsSegment);

        foreach (Match match in matches)
        {
            if (match.Groups.Count > 1)
            {
                // Fixed: explicitly call string.Empty instead of compiler ambiguous String.Empty
                string title = Regex.Replace(match.Groups[1].Value, "<.*?>", string.Empty).Trim();
                parsedPosts.Add(title);
            }
        }
        
        totalPostsCount = parsedPosts.Count;
    }
}