@page "/settings"
@inject AdminApp.Services.LocalStorageService LocalStorage
@inject AdminApp.Services.GitHubService GitHub

<h3 style="color:var(--primary-color); margin-bottom:20px;">System API Configurations</h3>

<div class="project-card" style="max-width:600px; margin:0 auto;">
    <div style="margin-bottom:15px;">
        <label style="display:block; font-weight:bold; margin-bottom:5px;">GitHub Username</label>
        <input type="text" @bind="owner" style="width:100%; padding:8px; border-radius:4px; border:1px solid #ddd;" />
    </div>
    <div style="margin-bottom:15px;">
        <label style="display:block; font-weight:bold; margin-bottom:5px;">Repository Name</label>
        <input type="text" @bind="repo" style="width:100%; padding:8px; border-radius:4px; border:1px solid #ddd;" />
    </div>
    <div style="margin-bottom:15px;">
        <label style="display:block; font-weight:bold; margin-bottom:5px;">GitHub Personal Access Token (PAT)</label>
        <input type="password" @bind="token" style="width:100%; padding:8px; border-radius:4px; border:1px solid #ddd;" />
    </div>
    <div style="margin-bottom:20px;">
        <label style="display:block; font-weight:bold; margin-bottom:5px;">DeepL Free API Key</label>
        <input type="password" @bind="deeplKey" style="width:100%; padding:8px; border-radius:4px; border:1px solid #ddd;" />
    </div>

    <div style="margin-bottom:20px;">
    <label style="display:block; font-weight:bold; margin-bottom:5px;">Substack Subdomain</label>
    <input type="text" @bind="substackSubdomain" placeholder="rami13kh"
           style="width:100%; padding:8px; border-radius:4px; border:1px solid #ddd;" />
    <small style="color:#718096;">Just the subdomain part, e.g. rami13kh (not the full URL)</small>
    </div>

    <button class="social-btn" @onclick="SaveSettings">Save Configuration Credentials</button>
    
    @if (!string.IsNullOrEmpty(statusMsg))
    {
        <p style="margin-top:15px; color:green; font-weight:bold;">@statusMsg</p>
    }
</div>

@code {
    private string owner = "";
    private string repo = "";
    private string token = "";
    private string deeplKey = "";
    private string statusMsg = "";
    private string substackSubdomain = "";

    protected override async Task OnInitializedAsync()
    {
        owner = await LocalStorage.GetItemAsync("gh_owner");
        repo = await LocalStorage.GetItemAsync("gh_repo");
        token = await LocalStorage.GetItemAsync("gh_token");
        deeplKey = await LocalStorage.GetItemAsync("deepl_key");
        substackSubdomain = await LocalStorage.GetItemAsync("substack_subdomain");
    }

    private async Task SaveSettings()
    {
        await LocalStorage.SetItemAsync("gh_owner", owner);
        await LocalStorage.SetItemAsync("gh_repo", repo);
        await LocalStorage.SetItemAsync("gh_token", token);
        await LocalStorage.SetItemAsync("deepl_key", deeplKey);
        await LocalStorage.SetItemAsync("substack_subdomain", substackSubdomain);
        
        GitHub.Initialize(token, owner, repo);
        statusMsg = "✅ Settings saved successfully to browser localStorage!";
    }
}