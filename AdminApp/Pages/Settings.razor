@page "/settings"
@using AdminApp.Services
@inject LocalStorageService LocalStorage

<div class="admin-container">
    <div class="admin-nav">
        <h2 class="admin-title"><i class="fa-solid fa-gear"></i> Settings</h2>
    </div>

    <div class="admin-card">
        <h4 style="margin-bottom:16px; color:#6B6B6B; font-size:0.85rem; text-transform:uppercase; letter-spacing:1px;">
            GitHub Configuration
        </h4>
        <div class="form-group">
            <label>Personal Access Token</label>
            <input type="password" class="form-control" @bind="ghToken" placeholder="ghp_..." />
            <small style="color:#6B6B6B;">Needs repo read/write scope.</small>
        </div>
        <div class="form-group">
            <label>Repository Owner</label>
            <input type="text" class="form-control" @bind="ghOwner" placeholder="your-github-username" />
        </div>
        <div class="form-group">
            <label>Repository Name</label>
            <input type="text" class="form-control" @bind="ghRepo" placeholder="Portfolio" />
        </div>
        <button class="btn-admin btn-primary-admin" @onclick="SaveAsync">
            <i class="fa-solid fa-floppy-disk"></i> Save Settings
        </button>
        @if (!string.IsNullOrEmpty(savedMsg))
        {
            <span style="margin-right:16px; color:#276749; font-weight:600;">@savedMsg</span>
        }
    </div>
</div>

@code {
    private string ghToken = string.Empty;
    private string ghOwner = string.Empty;
    private string ghRepo  = string.Empty;
    private string savedMsg = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        ghToken = await LocalStorage.GetItemAsync("gh_token");
        ghOwner = await LocalStorage.GetItemAsync("gh_owner");
        ghRepo  = await LocalStorage.GetItemAsync("gh_repo");
    }

    private async Task SaveAsync()
    {
        await LocalStorage.SetItemAsync("gh_token", ghToken);
        await LocalStorage.SetItemAsync("gh_owner", ghOwner);
        await LocalStorage.SetItemAsync("gh_repo",  ghRepo);
        savedMsg = "✅ Saved.";
        await Task.Delay(2000);
        savedMsg = string.Empty;
    }
}