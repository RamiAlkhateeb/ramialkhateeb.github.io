@page "/add-guide"
@using AdminApp.Models
@using AdminApp.Services
@inject LocalStorageService LocalStorage
@inject GitHubService GitHub

<div class="admin-container">
    <div class="admin-nav">
        <h2 class="admin-title"><i class="fa-solid fa-book"></i> نشر دليل جديد</h2>
        <a href="/settings" class="btn-admin btn-secondary-admin" style="text-decoration:none; padding:8px 16px;">
            <i class="fa-solid fa-gear"></i> Settings
        </a>
    </div>

    <div class="admin-card">
        <div class="form-group">
            <label>عنوان الدليل بالعربية</label>
            <input type="text" class="form-control" @bind="guide.TitleAr"
                   placeholder="عنوان الدليل..." style="font-weight:700; font-size:1rem;" />
        </div>
        <div class="form-group">
            <label>الملخص بالعربية</label>
            <textarea class="form-control" @bind="guide.SummaryAr"
                      placeholder="وصف مختصر للدليل..."
                      style="height:80px;"></textarea>
        </div>
        <div class="form-group">
            <label>رابط Payhip</label>
            <input type="url" class="form-control" @bind="guide.PayhipUrl"
                   placeholder="https://payhip.com/b/..." />
        </div>
        <div class="form-group">
            <label>السعر</label>
            <input type="text" class="form-control" @bind="guide.PriceLabel"
                   placeholder="19.99€" style="font-family:'Inter',sans-serif;" />
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(guide.TitleAr))
    {
        <div class="admin-card" style="border-top: 3px solid #1C1C1C;">
            <h4 style="margin-bottom:12px; font-size:0.85rem; color:#6B6B6B; text-transform:uppercase; letter-spacing:1px;">
                معاينة البطاقة
            </h4>
            <div style="border:2px solid #E0E0DC; background:#fff; font-family:'Tajawal',sans-serif; direction:rtl; max-width:320px;">
                <div style="height:130px; background:#1C1C1C; display:flex; align-items:center; justify-content:center;">
                    <i class="fas fa-book" style="color:rgba(255,255,255,0.2); font-size:2rem;"></i>
                </div>
                <div style="padding:18px;">
                    <div style="font-weight:700; font-size:0.98rem; margin-bottom:8px;">@guide.TitleAr</div>
                    <div style="font-size:0.85rem; color:#6B6B6B; margin-bottom:16px;">@guide.SummaryAr</div>
                    <div style="display:flex; justify-content:space-between; align-items:center; border-top:1px solid #E0E0DC; padding-top:12px;">
                        <span style="font-weight:800; font-family:'Inter',sans-serif;">@guide.PriceLabel</span>
                        <span style="background:#1C1C1C; color:#fff; padding:6px 12px; font-size:0.82rem; font-weight:700;">شراء ←</span>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="btn-group" style="margin-top:8px;">
        <button class="btn-admin btn-primary-admin"
                @onclick="PublishGuideAsync"
                disabled="@(string.IsNullOrWhiteSpace(guide.TitleAr) || string.IsNullOrWhiteSpace(guide.PayhipUrl) || isCommitting)">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            @(isCommitting ? "جارٍ النشر..." : "نشر على الموقع")
        </button>
    </div>

    @if (!string.IsNullOrEmpty(feedbackMsg))
    {
        <div class="admin-card" style="margin-top:20px; text-align:center; font-weight:600; padding:14px; color:#4a5568; background:#edf2f7; border:none;">
            @feedbackMsg
        </div>
    }
</div>

@code {
    private GuideEntry guide = new();
    private bool isCommitting = false;
    private string feedbackMsg = string.Empty;

    private async Task PublishGuideAsync()
    {
        isCommitting = true;
        feedbackMsg  = "⏳ جارٍ الاتصال بـ GitHub...";
        StateHasChanged();

        try
        {
            string token = await LocalStorage.GetItemAsync("gh_token");
            string owner = await LocalStorage.GetItemAsync("gh_owner");
            string repo  = await LocalStorage.GetItemAsync("gh_repo");

            if (!GitHub.IsConfigured)
                GitHub.Initialize(token, owner, repo);

            string newCard = $@"
                <div class=""guide-card"">
                    <div class=""guide-card-pattern"">
                        <i class=""fas fa-book""></i>
                    </div>
                    <div class=""guide-card-body"">
                        <div class=""guide-card-title"">{guide.TitleAr}</div>
                        <div class=""guide-card-summary"">{guide.SummaryAr}</div>
                        <div class=""guide-card-footer"">
                            <span class=""guide-price"">{guide.PriceLabel}</span>
                            <a href=""{guide.PayhipUrl}"" class=""btn-primary"" style=""font-size:0.82rem; padding:7px 14px;"" target=""_blank"">
                                شراء <i class=""fa-solid fa-arrow-left""></i>
                            </a>
                        </div>
                    </div>
                </div>";

            feedbackMsg = "⏳ جارٍ حقن البطاقة في index.html...";
            StateHasChanged();

            await GitHub.InjectBetweenMarkersAsync(
                "index.html",
                "<!-- GUIDES_START -->",
                "<!-- GUIDES_END -->",
                newCard,
                $"Add guide: {guide.TitleAr[..Math.Min(50, guide.TitleAr.Length)]}");

            feedbackMsg = "🚀 تم النشر! سيتحدث الموقع خلال ثوانٍ.";
            guide = new GuideEntry();
        }
        catch (Exception ex)
        {
            feedbackMsg = $"❌ فشل النشر: {ex.Message}";
        }
        finally
        {
            isCommitting = false;
        }
    }
}
