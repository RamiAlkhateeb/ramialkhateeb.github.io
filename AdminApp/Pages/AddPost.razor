@page "/add-post"
@using AdminApp.Models
@using AdminApp.Services
@inject LocalStorageService LocalStorage
@inject GitHubService GitHub

<div class="admin-container">
    <div class="admin-nav">
        <h2 class="admin-title"><i class="fa-brands fa-linkedin"></i> نشر مقال LinkedIn</h2>
        <a href="/settings" class="btn-admin btn-secondary-admin" style="text-decoration:none; padding:8px 16px;">
            <i class="fa-solid fa-gear"></i> Settings
        </a>
    </div>

    <div class="admin-card">
        <div class="form-group">
            <label>العنوان بالعربية</label>
            <input type="text" class="form-control" @bind="post.TitleAr"
                   placeholder="عنوان المقال..." style="font-weight:700; font-size:1rem;" />
        </div>
        <div class="form-group">
            <label>الملخص بالعربية</label>
            <textarea class="form-control" @bind="post.SummaryAr"
                      placeholder="ملخص قصير يظهر تحت العنوان..."
                      style="height:80px;"></textarea>
        </div>
        <div class="form-group">
            <label>رابط منشور LinkedIn</label>
            <input type="url" class="form-control" @bind="post.LinkedInUrl"
                   placeholder="https://www.linkedin.com/posts/..." />
        </div>
        <div class="form-group">
            <label>التاريخ</label>
            <input type="date" class="form-control"
                   value="@DateString"
                   @onchange="OnDateChanged" />
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(post.TitleAr))
    {
        <div class="admin-card" style="border-top: 3px solid #1C1C1C;">
            <h4 style="margin-bottom:12px; font-size:0.85rem; color:#6B6B6B; text-transform:uppercase; letter-spacing:1px;">
                معاينة البطاقة
            </h4>
            <div style="display:flex; align-items:stretch; border:2px solid #E0E0DC; background:#fff; font-family:'Tajawal',sans-serif; direction:rtl;">
                <div style="width:64px; flex-shrink:0; background:#1C1C1C; display:flex; align-items:center; justify-content:center;">
                    <i class="fab fa-linkedin" style="color:rgba(255,255,255,0.2); font-size:1.2rem;"></i>
                </div>
                <div style="flex:1; padding:14px 18px;">
                    <div style="font-weight:700; font-size:0.96rem; margin-bottom:4px;">@post.TitleAr</div>
                    <div style="font-size:0.84rem; color:#6B6B6B;">@post.SummaryAr</div>
                </div>
                <div style="padding:14px 16px 14px 0; display:flex; flex-direction:column; align-items:flex-end; justify-content:center; gap:6px;">
                    <span style="font-size:0.76rem; font-weight:600; color:#6B6B6B; font-family:'Inter',sans-serif;">@post.Date</span>
                    <span style="font-size:0.76rem; font-weight:700; font-family:'Inter',sans-serif;">LinkedIn ←</span>
                </div>
            </div>
        </div>
    }

    <div class="btn-group" style="margin-top:8px;">
        <button class="btn-admin btn-primary-admin"
                @onclick="PublishPostAsync"
                disabled="@(string.IsNullOrWhiteSpace(post.TitleAr) || string.IsNullOrWhiteSpace(post.LinkedInUrl) || isCommitting)">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            @(isCommitting ? "جارٍ النشر..." : "نشر على الموقع")
        </button>
    </div>

    @if (!string.IsNullOrEmpty(feedbackMsg))
    {
        <div class="admin-card" style="margin-top:20px; text-align:center; font-weight:600; padding:14px; color:#4a5568; background:#edf2f7; border:none;">
            @feedbackMsg
        </div>
    }
</div>

@code {
    private PostEntry post = new();
    private DateTime _dateValue = DateTime.Now;
    private string DateString => _dateValue.ToString("yyyy-MM-dd");
    private bool isCommitting = false;
    private string feedbackMsg = string.Empty;

    private void OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d))
        {
            _dateValue = d;
            post.Date  = d.ToString("yyyy-MM-dd");
        }
    }

    private async Task PublishPostAsync()
    {
        isCommitting = true;
        feedbackMsg  = "⏳ جارٍ الاتصال بـ GitHub...";
        StateHasChanged();

        try
        {
            string token = await LocalStorage.GetItemAsync("gh_token");
            string owner = await LocalStorage.GetItemAsync("gh_owner");
            string repo  = await LocalStorage.GetItemAsync("gh_repo");

            if (!GitHub.IsConfigured)
                GitHub.Initialize(token, owner, repo);

            string newCard = $@"
                <a href=""{post.LinkedInUrl}"" target=""_blank"" class=""post-card"">
                    <div class=""post-card-pattern"">
                        <i class=""fab fa-linkedin""></i>
                    </div>
                    <div class=""post-card-body"">
                        <div class=""post-card-title"">{post.TitleAr}</div>
                        <div class=""post-card-summary"">{post.SummaryAr}</div>
                    </div>
                    <div class=""post-card-meta"">
                        <span class=""post-card-date"">{post.Date}</span>
                        <span class=""post-card-arrow"">LinkedIn ←</span>
                    </div>
                </a>";

            feedbackMsg = "⏳ جارٍ حقن البطاقة في index.html...";
            StateHasChanged();

            await GitHub.InjectBetweenMarkersAsync(
                "index.html",
                "<!-- POSTS_START -->",
                "<!-- POSTS_END -->",
                newCard,
                $"Add post: {post.TitleAr[..Math.Min(50, post.TitleAr.Length)]}");

            feedbackMsg = "🚀 تم النشر! سيتحدث الموقع خلال ثوانٍ.";
            post = new PostEntry();
            _dateValue = DateTime.Now;
        }
        catch (Exception ex)
        {
            feedbackMsg = $"❌ فشل النشر: {ex.Message}";
        }
        finally
        {
            isCommitting = false;
        }
    }
}
