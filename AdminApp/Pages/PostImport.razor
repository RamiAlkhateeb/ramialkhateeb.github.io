@page "/import"
@using System.Text.Json
@using AdminApp.Models
@using AdminApp.Services
@inject LocalStorageService LocalStorage
@inject GitHubService GitHub
@inject TranslationService Translator
@inject SubstackService SubstackFetcher

<div class="admin-container">
    <div class="admin-nav">
        <h2 class="admin-title"><i class="fa-solid fa-language"></i> Localization Workspace</h2>
        <a href="/settings" class="btn-admin btn-secondary-admin" style="text-decoration:none; padding: 8px 16px;">
            <i class="fa-solid fa-gear"></i> Settings
        </a>
    </div>

    <!-- ── Step 1: Pick a Substack post ───────────────────────────────────── -->
    <div class="admin-card" style="border-left: 4px solid #ff5447;">
        <h4 style="color:#ff5447; margin-bottom:16px;">
            <i class="fa-solid fa-rss"></i> Step 1 — Pick a Substack Post
        </h4>

        @if (isLoadingPosts)
        {
            <p style="color:#718096;"><i class="fa-solid fa-spinner fa-spin"></i> Loading your Substack posts...</p>
        }
        else if (loadPostsError is not null)
        {
            <p style="color:#e53e3e;"><i class="fa-solid fa-circle-exclamation"></i> @loadPostsError</p>
            <button class="btn-admin btn-secondary-admin" style="margin-top:8px;" @onclick="LoadSubstackPosts">
                <i class="fa-solid fa-rotate-right"></i> Retry
            </button>
        }
        else if (availablePosts.Count == 0)
        {
            <p style="color:#718096;">No published posts found on your Substack.</p>
        }
        else
        {
            <div style="display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: flex-end;">
                <div class="form-group" style="margin:0;">
                    <label>Select Article</label>
                    <select class="form-control" @bind="selectedSlug">
                        <option value="">— choose a post —</option>
                        @foreach (var p in availablePosts)
                        {
                            <option value="@p.Slug">@p.PostDate.ToString("yyyy-MM-dd") · @p.Title</option>
                        }
                    </select>
                </div>
                <button class="btn-admin btn-primary-admin"
                        style="background-color:#ff5447; height:42px;"
                        @onclick="ImportSelectedPost"
                        disabled="@(string.IsNullOrEmpty(selectedSlug))">
                    <i class="fa-solid fa-file-import"></i> Import
                </button>
            </div>

            @if (importedPost is not null)
            {
                <div style="margin-top:14px; padding:10px 14px; background:#f0fff4; border-radius:8px; border:1px solid #9ae6b4; font-size:0.9rem; color:#276749;">
                    <i class="fa-solid fa-circle-check"></i>
                    <strong>@importedPost.Title</strong> imported.
                    Published @importedPost.PostDate.ToString("dd MMM yyyy").
                    @if (!string.IsNullOrWhiteSpace(importedPost.CoverImage))
                    {
                        <span> Cover image found.</span>
                    }
                </div>
            }
        }
    </div>

    <!-- ── Step 2: Edit content in all three languages ────────────────────── -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 24px;">

        <!-- English -->
        <div class="admin-card" style="border-top: 4px solid #0056b3;">
            <h4 style="color:#0056b3;">
                <i class="fa-solid fa-flag-usa"></i> English (Source)
            </h4>
            <div class="form-group">
                <label>Title</label>
                <input type="text" class="form-control" @bind="post.TitleEn"
                       placeholder="English title..." style="font-weight:bold;" />
            </div>
            <div class="form-group">
                <label>Summary</label>
                <textarea class="form-control" @bind="post.SummaryEn"
                          placeholder="Short summary shown on the blog list..."
                          style="height:65px;"></textarea>
            </div>
            <div class="form-group">
                <label>Publishing Date</label>
                <input type="date" class="form-control" @bind="post.Date" />
            </div>
            <div class="form-group">
                <label>Body HTML</label>
                <textarea class="form-control" @bind="post.BodyEn"
                          placeholder="HTML body (auto-filled from Substack)..."
                          style="height:320px; font-family:monospace; font-size:0.82rem;"></textarea>
            </div>
        </div>

        <!-- German -->
        <div class="admin-card" style="border-top: 4px solid #de2010;">
            <h4 style="color:#de2010;">
                <i class="fa-solid fa-flag-germany"></i> Deutsch
            </h4>
            <div class="form-group">
                <label>Titel</label>
                <input type="text" class="form-control" @bind="post.TitleDe"
                       placeholder="Deutschen Titel eingeben..." style="font-weight:bold;" />
            </div>
            <div class="form-group">
                <label>Zusammenfassung</label>
                <textarea class="form-control" @bind="post.SummaryDe"
                          placeholder="Kurze deutsche Beschreibung..."
                          style="height:65px;"></textarea>
            </div>
            <div class="form-group" style="margin-top:47px;">
                <label>Inhalt (HTML)</label>
                <textarea class="form-control" @bind="post.BodyDe"
                          placeholder="Deutschen Inhalt hier..."
                          style="height:320px; font-family:monospace; font-size:0.82rem;"></textarea>
            </div>
        </div>

        <!-- Arabic -->
        <div class="admin-card" style="border-top: 4px solid #007a3d;" dir="rtl">
            <h4 style="color:#007a3d; text-align:right;">
                <i class="fa-solid fa-globe"></i> العربية
            </h4>
            <div class="form-group">
                <label style="display:block; text-align:right;">العنوان</label>
                <input type="text" class="form-control" @bind="post.TitleAr"
                       placeholder="عنوان المقال..." style="font-weight:bold; text-align:right;" />
            </div>
            <div class="form-group">
                <label style="display:block; text-align:right;">الملخص</label>
                <textarea class="form-control" @bind="post.SummaryAr"
                          placeholder="ملخص قصير..."
                          style="height:65px; text-align:right;"></textarea>
            </div>
            <div class="form-group" style="margin-top:47px;">
                <label style="display:block; text-align:right;">المحتوى (HTML)</label>
                <textarea class="form-control" @bind="post.BodyAr"
                          placeholder="المحتوى هنا..."
                          style="height:320px; text-align:right; font-family:monospace; font-size:0.82rem;"></textarea>
            </div>
        </div>
    </div>

    <!-- ── Step 3: Translate + Publish ───────────────────────────────────── -->
    <div class="btn-group" style="margin-top:8px;">
        <button class="btn-admin btn-secondary-admin"
                @onclick="TranslateDeAsync"
                disabled="@(string.IsNullOrWhiteSpace(post.BodyEn) || isTranslating)">
            <i class="fa-solid fa-flag-germany"></i>
            @(isTranslating && translatingTarget == "DE" ? "Translating..." : "Translate DE via DeepL")
        </button>

        <button class="btn-admin btn-secondary-admin"
                @onclick="TranslateArAsync"
                disabled="@(string.IsNullOrWhiteSpace(post.BodyEn) || isTranslating)"
                style="border-color:#007a3d; color:#007a3d;">
            <i class="fa-solid fa-globe"></i>
            @(isTranslating && translatingTarget == "AR" ? "Translating..." : "Translate AR via DeepL")
        </button>

        <button class="btn-admin btn-primary-admin"
                @onclick="CommitPostToGitHub"
                disabled="@(string.IsNullOrWhiteSpace(post.TitleEn) || isCommitting)">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            @(isCommitting ? "Committing..." : "Commit & Deploy")
        </button>
    </div>

    @if (!string.IsNullOrEmpty(feedbackMsg))
    {
        <div class="admin-card" style="margin-top:20px; text-align:center; font-weight:600;
                    padding:14px; color:#4a5568; background-color:#edf2f7; border:none;">
            <i class="fa-solid fa-circle-info"></i> @feedbackMsg
        </div>
    }
</div>

@code {
    // ── State ─────────────────────────────────────────────────────────────────
    private BlogPost post = new() { Date = DateTime.Now };

    private List<SubstackPost> availablePosts = new();
    private SubstackPost? importedPost;
    private string selectedSlug = string.Empty;

    private bool isLoadingPosts  = false;
    private bool isTranslating   = false;
    private bool isCommitting    = false;
    private string translatingTarget = string.Empty;
    private string? loadPostsError;
    private string feedbackMsg = string.Empty;

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadSubstackPosts();
    }

    // ── Load post list from Substack API ─────────────────────────────────────
    private async Task LoadSubstackPosts()
    {
        isLoadingPosts = true;
        loadPostsError = null;
        StateHasChanged();

        try
        {
            string subdomain = await LocalStorage.GetItemAsync("substack_subdomain");

            if (string.IsNullOrWhiteSpace(subdomain))
            {
                loadPostsError = "Substack subdomain not set. Go to Settings and add it.";
                return;
            }

            availablePosts = await SubstackFetcher.FetchAllPostsAsync(subdomain);
            availablePosts = availablePosts.Where(p => p.IsPublished).ToList();
        }
        catch (Exception ex)
        {
            loadPostsError = $"Could not load Substack posts: {ex.Message}";
        }
        finally
        {
            isLoadingPosts = false;
        }
    }

    // ── Import selected post into form ────────────────────────────────────────
    private async Task ImportSelectedPost()
    {
        if (string.IsNullOrEmpty(selectedSlug)) return;

        feedbackMsg = "⏳ Importing post...";

        try
        {
            string subdomain = await LocalStorage.GetItemAsync("substack_subdomain");
            importedPost = await SubstackFetcher.FetchPostBySlugAsync(subdomain, selectedSlug);

            if (importedPost is null)
            {
                feedbackMsg = "❌ Post not found. Try refreshing the list.";
                return;
            }

            // Fill the form from Substack data
            post.Slug         = importedPost.Slug;
            post.TitleEn      = importedPost.Title;
            post.SummaryEn    = importedPost.Subtitle;
            post.BodyEn       = SubstackFetcher.CleanBodyHtml(importedPost.BodyHtml);
            post.Date         = importedPost.PostDate.ToLocalTime();
            post.CoverImageUrl = importedPost.CoverImage;
            post.SubstackUrl  = importedPost.CanonicalUrl;

            // Clear previous translations so user doesn't accidentally publish stale DE/AR
            post.TitleDe = post.SummaryDe = post.BodyDe = string.Empty;
            post.TitleAr = post.SummaryAr = post.BodyAr = string.Empty;

            feedbackMsg = $"✅ \"{importedPost.Title}\" imported. Review the content, then translate and publish.";
        }
        catch (Exception ex)
        {
            feedbackMsg = $"❌ Import failed: {ex.Message}";
        }
    }

    // ── Translate to German via DeepL ─────────────────────────────────────────
    private async Task TranslateDeAsync()
    {
        string key = await LocalStorage.GetItemAsync("deepl_key");

        if (string.IsNullOrEmpty(key))
        {
            feedbackMsg = "❌ DeepL API key missing — add it in Settings.";
            return;
        }

        isTranslating    = true;
        translatingTarget = "DE";
        feedbackMsg      = "⏳ Translating to German via DeepL...";
        StateHasChanged();

        try
        {
            post.TitleDe   = await Translator.TranslateTextAsync(post.TitleEn,   "DE", key);
            post.SummaryDe = await Translator.TranslateTextAsync(post.SummaryEn, "DE", key);
            post.BodyDe    = await Translator.TranslateTextAsync(post.BodyEn,    "DE", key);
            feedbackMsg    = "✅ German translation done. Review and correct before publishing.";
        }
        catch (Exception ex)
        {
            feedbackMsg = $"❌ DeepL error: {ex.Message}";
        }
        finally
        {
            isTranslating = false;
            translatingTarget = string.Empty;
        }
    }

    // ── Translate to Arabic ───────────────────────────────────────────────────
    // Currently routed through DeepL (same as DE).
    // TODO: swap Translator.TranslateTextAsync for a GoogleTranslateService call
    // when you wire up the Google Translate API key in Settings.
    private async Task TranslateArAsync()
    {
        string key = await LocalStorage.GetItemAsync("deepl_key");

        if (string.IsNullOrEmpty(key))
        {
            feedbackMsg = "❌ DeepL API key missing — add it in Settings.";
            return;
        }

        isTranslating     = true;
        translatingTarget = "AR";
        feedbackMsg       = "⏳ Translating to Arabic...";
        StateHasChanged();

        try
        {
            post.TitleAr   = await Translator.TranslateTextAsync(post.TitleEn,   "AR", key);
            post.SummaryAr = await Translator.TranslateTextAsync(post.SummaryEn, "AR", key);
            post.BodyAr    = await Translator.TranslateTextAsync(post.BodyEn,    "AR", key);
            feedbackMsg    = "✅ Arabic translation done. Review and correct before publishing.";
        }
        catch (Exception ex)
        {
            feedbackMsg = $"❌ Translation error: {ex.Message}";
        }
        finally
        {
            isTranslating = false;
            translatingTarget = string.Empty;
        }
    }

    // ── Commit to GitHub ─────────────────────────────────────────────────────
    private async Task CommitPostToGitHub()
    {
        feedbackMsg  = "⏳ Accessing GitHub repository...";
        isCommitting = true;
        StateHasChanged();

        try
        {
            string token = await LocalStorage.GetItemAsync("gh_token");
            string owner = await LocalStorage.GetItemAsync("gh_owner");
            string repo  = await LocalStorage.GetItemAsync("gh_repo");

            if (!GitHub.IsConfigured)
                GitHub.Initialize(token, owner, repo);

            post.IsPublished = true;

            var jsonOptions = new JsonSerializerOptions { WriteIndented = true };

            // 1. Fetch current index.json and update it
            List<BlogIndexEntry> indexList = new();
            string indexPath = "content/blog/index.json";

            try
            {
                string raw = await GitHub.GetFileRawAsync(indexPath);
                indexList  = JsonSerializer.Deserialize<List<BlogIndexEntry>>(raw, jsonOptions) ?? new();
            }
            catch { /* File doesn't exist yet — start fresh */ }

            indexList.RemoveAll(i => i.Slug == post.Slug);
            indexList.Insert(0, new BlogIndexEntry
            {
                Slug          = post.Slug,
                TitleEn       = post.TitleEn,   TitleDe  = post.TitleDe,   TitleAr  = post.TitleAr,
                SummaryEn     = post.SummaryEn, SummaryDe = post.SummaryDe, SummaryAr = post.SummaryAr,
                CoverImageUrl = post.CoverImageUrl,
                SubstackUrl   = post.SubstackUrl,
                Date          = post.Date,
                IsPublished   = true
            });

            // 2. Commit both files
            string updatedIndex = JsonSerializer.Serialize(indexList, jsonOptions);
            string postJson     = JsonSerializer.Serialize(post, jsonOptions);

            feedbackMsg = "⏳ Committing post file...";
            StateHasChanged();
            await GitHub.SaveFileContentAsync(
                $"content/blog/posts/{post.Slug}.json",
                postJson,
                $"Add post: {post.Slug}");

            feedbackMsg = "⏳ Updating index...";
            StateHasChanged();
            await GitHub.SaveFileContentAsync(
                indexPath,
                updatedIndex,
                $"Update blog index: {post.Slug}");

            // 3. Trigger GitHub Actions site compiler
            feedbackMsg = "⏳ Triggering site compiler...";
            StateHasChanged();
            await GitHub.TriggerWorkflowCompilerAsync();

            feedbackMsg = "🚀 Done! Site will update in about 30 seconds.";
        }
        catch (Exception ex)
        {
            feedbackMsg = $"❌ Commit failed: {ex.Message}";
        }
        finally
        {
            isCommitting = false;
        }
    }
}
